generator client {
  provider = "prisma-client-js"
  output   = "./client"
}

datasource db {
  provider = "postgresql"
}

model File {
  id            String     @id @default(uuid()) @db.Uuid
  s3Key         String     @map("s3_key")
  bucket        String
  fileExtension String     @map("file_extension") // avatar, post_image, document, media
  fileType      FileType   @map("file_type")
  status        FileStatus @default(PENDING)
  userId        String     @map("user_id") @db.Uuid
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")
  deletedAt     DateTime?

  @@index([userId])
  @@index([status])
  @@index([fileExtension])
  @@map("files")
}

enum FileStatus {
  PENDING
  UPLOADED
  FAILED
  DELETING
  FAILED_DELETE
}

enum FileType {
  AVATAR
  POST_IMAGE
  DOCUMENT
  MEDIA
}
