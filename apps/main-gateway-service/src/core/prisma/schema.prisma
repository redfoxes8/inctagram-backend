generator client {
  provider = "prisma-client-js"
  output   = "../../../../../../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

// Add your schemas here. To migrate changes into DB use 'pnpm run prisma:migrate --name YOUR_MIGRATION_NAME' command.
model User {
  id    Int     @id @default(autoincrement())
  email String  @unique
  name  String?
}
